{
     "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
     "include": [
          "src/renderer/src/**/*",
          "src/shared/**/*"
     ],
     "compilerOptions": {
          "composite": true,
          "baseUrl": ".",
          "jsx": "react-jsx",
          "target": "ESNext",
          "module": "ESNext",
          "moduleResolution": "bundler",
          "paths": {
               "@renderer/*": [
                    "src/renderer/src/*"
               ],
               "@shared/*": [
                    "src/shared/*"
               ]
          }
     }
}